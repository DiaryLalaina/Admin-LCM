<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox alignment="CENTER" style="-fx-border-color: WHITE WHITE BLACK WHITE; -fx-border-width: 0.5;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.work.cashier.controller.infoTable.OrderPaymentInfo">
   <children>
      <Label fx:id="reference" alignment="CENTER" maxWidth="-Infinity" minWidth="-Infinity" prefWidth="130.0" text="REFERENCE">
         <font>
            <Font name="JetBrains Mono Regular" size="14.0" />
         </font>
      </Label>
      <Label fx:id="quantity" alignment="CENTER" layoutX="11.0" layoutY="16.0" maxWidth="-Infinity" minWidth="-Infinity" prefWidth="70.0" text="QTE">
         <font>
            <Font name="JetBrains Mono Regular" size="14.0" />
         </font>
      </Label>
      <Label fx:id="total" alignment="CENTER" layoutX="46.0" layoutY="52.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="TOTAL" HBox.hgrow="SOMETIMES">
         <font>
            <Font name="JetBrains Mono Regular" size="14.0" />
         </font>
      </Label>
      <Label fx:id="advance" alignment="CENTER" layoutX="73.0" layoutY="52.0" maxWidth="-Infinity" minWidth="-Infinity" prefWidth="120.0" text="AVANCE">
         <font>
            <Font name="JetBrains Mono Regular" size="14.0" />
         </font>
      </Label>
      <Label fx:id="remain" alignment="CENTER" layoutX="184.0" layoutY="16.0" maxWidth="-Infinity" minWidth="-Infinity" prefWidth="120.0" text="RESTE">
         <font>
            <Font name="JetBrains Mono Regular" size="14.0" />
         </font>
      </Label>
      <JFXButton fx:id="paymentBtn" contentDisplay="GRAPHIC_ONLY" onAction="#payment" ripplerFill="#6088f5" style="-fx-background-color: #cfd7ed8F;">
         <HBox.margin>
            <Insets bottom="3.0" right="3.0" top="3.0" />
         </HBox.margin>
      </JFXButton>
   </children>
</HBox>
