<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="10.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/15.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.work.cashier.controller.page.Unpaid">
   <children>
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <HBox alignment="CENTER" style="-fx-background-color: ECECEC;" HBox.hgrow="SOMETIMES">
               <children>
                  <Label text="TOTAL :" wrapText="true">
                     <font>
                        <Font name="JetBrains Mono Bold" size="16.0" />
                     </font>
                  </Label>
                  <Label fx:id="totalAmount" text="0" wrapText="true">
                     <font>
                        <Font name="JetBrains Mono Bold" size="16.0" />
                     </font>
                     <padding>
                        <Insets left="5.0" />
                     </padding>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="3.0" top="3.0" />
               </padding>
            </HBox>
            <HBox alignment="CENTER" style="-fx-background-color: ECECEC;" HBox.hgrow="SOMETIMES">
               <children>
                  <Label text="PAYE :" wrapText="true">
                     <font>
                        <Font name="JetBrains Mono Bold" size="16.0" />
                     </font>
                  </Label>
                  <Label fx:id="paid" text="0" wrapText="true">
                     <font>
                        <Font name="JetBrains Mono Bold" size="16.0" />
                     </font>
                     <padding>
                        <Insets left="5.0" />
                     </padding>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="3.0" top="3.0" />
               </padding>
            </HBox>
            <HBox alignment="CENTER" style="-fx-background-color: ECECEC;" HBox.hgrow="SOMETIMES">
               <children>
                  <Label text="RESTE :" wrapText="true">
                     <font>
                        <Font name="JetBrains Mono Bold" size="16.0" />
                     </font>
                  </Label>
                  <Label fx:id="remain" text="0" wrapText="true">
                     <font>
                        <Font name="JetBrains Mono Bold" size="16.0" />
                     </font>
                     <padding>
                        <Insets left="5.0" />
                     </padding>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="3.0" top="3.0" />
               </padding>
            </HBox>
            <JFXButton fx:id="printBtn" contentDisplay="GRAPHIC_ONLY" onAction="#print" style="-fx-background-color: #CFDBC5;">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
            </JFXButton>
         </children>
         <padding>
            <Insets left="10.0" right="10.0" />
         </padding>
      </HBox>
      <HBox alignment="CENTER_LEFT" style="-fx-background-color: #CFDBC5; -fx-border-width: 0.5;">
         <children>
            <Label alignment="CENTER" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="27.0" prefWidth="130.0" style="-fx-border-color: TRANSPARENT WHITE TRANSPARENT TRANSPARENT; -fx-border-width: 1;" text="CLIENT" HBox.hgrow="SOMETIMES">
               <font>
                  <Font name="JetBrains Mono Medium" size="14.0" />
               </font>
            </Label>
            <Label alignment="CENTER" layoutX="10.0" layoutY="13.0" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="27.0" prefWidth="200.0" style="-fx-border-color: TRANSPARENT WHITE; -fx-border-width: 1;" text="TOTAL">
               <font>
                  <Font name="JetBrains Mono Medium" size="14.0" />
               </font>
            </Label>
            <Label alignment="CENTER" layoutX="10.0" layoutY="11.0" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="27.0" prefWidth="200.0" text="PAYE">
               <font>
                  <Font name="JetBrains Mono Medium" size="14.0" />
               </font>
            </Label>
            <Label alignment="CENTER" layoutX="80.0" layoutY="10.0" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="27.0" prefWidth="200.0" style="-fx-border-color: TRANSPARENT WHITE; -fx-border-width: 1;" text="RESTE">
               <font>
                  <Font name="JetBrains Mono Medium" size="14.0" />
               </font>
            </Label>
            <Label alignment="CENTER" layoutX="700.0" layoutY="10.0" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="27.0" prefWidth="100.0" style="-fx-border-color: TRANSPARENT WHITE; -fx-border-width: 1;" text="ACTION">
               <font>
                  <Font name="JetBrains Mono Medium" size="14.0" />
               </font>
            </Label>
         </children>
      </HBox>
      <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" onMouseEntered="#onMouseEntered" onMouseExited="#onMouseExited" style="-fx-background-color: white;" styleClass="scroll-bar" stylesheets="@../style/scroll.css" VBox.vgrow="SOMETIMES">
         <content>
            <VBox fx:id="containerData" alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: WHITE;" />
         </content>
      </ScrollPane>
   </children>
   <padding>
      <Insets top="10.0" />
   </padding>
</VBox>
